// Esquema Prisma — Vialta API
// Modelo de dominio inicial para transporte multimodal, multiempresa y multisucursal.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// Enums
// ----------------------------------------------------------------------------

enum TransportMode {
  AIR
  BUS
  TRAIN
  PRIVATE
}

enum TravelClass {
  ECONOMY
  PREMIUM_ECONOMY
  BUSINESS
  FIRST
  STANDARD
  EXECUTIVE
  VIP
  SLEEPER
}

enum UserRole {
  TRAVELER
  OPERATOR_ADMIN
  STAFF
  PLATFORM_ADMIN
}

enum BookingStatus {
  DRAFT
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum SeatStatus {
  AVAILABLE
  HELD
  BOOKED
  BLOCKED
}

// ----------------------------------------------------------------------------
// Multiempresa / multisucursal
// ----------------------------------------------------------------------------

model Company {
  id         String          @id @default(cuid())
  name       String
  slug       String          @unique
  modes      TransportMode[]
  logoMark   String
  brandColor String          @default("#6a5cff")
  rating     Float           @default(0)
  countryCode String         @default("PE")
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  branches   Branch[]
  vehicles   Vehicle[]
  routes     Route[]
  trips      Trip[]
  staff      User[]
}

model Branch {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  city      String
  countryCode String @default("PE")
  createdAt DateTime @default(now())

  @@index([companyId])
}

// ----------------------------------------------------------------------------
// Catálogo de transporte
// ----------------------------------------------------------------------------

model Place {
  id          String        @id @default(cuid())
  code        String        @unique
  name        String
  city        String
  country     String
  countryCode String
  kind        String // airport | bus_terminal | train_station | private_hub | city
  lat         Float?
  lng         Float?

  routesFrom  Route[]       @relation("RouteOrigin")
  routesTo    Route[]       @relation("RouteDestination")
}

model Vehicle {
  id        String        @id @default(cuid())
  companyId String
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  mode      TransportMode
  name      String // "Airbus A320neo", "Volvo 9800"
  capacity  Int
  createdAt DateTime      @default(now())

  trips     Trip[]
  seats     Seat[]

  @@index([companyId])
}

model Route {
  id            String        @id @default(cuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  mode          TransportMode
  originId      String
  origin        Place         @relation("RouteOrigin", fields: [originId], references: [id])
  destinationId String
  destination   Place         @relation("RouteDestination", fields: [destinationId], references: [id])
  trips         Trip[]

  @@index([companyId])
  @@index([originId, destinationId])
}

// Una salida concreta (horario) de un vehículo sobre una ruta.
model Trip {
  id            String        @id @default(cuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  routeId       String
  route         Route         @relation(fields: [routeId], references: [id], onDelete: Cascade)
  vehicleId     String?
  vehicle       Vehicle?      @relation(fields: [vehicleId], references: [id])
  mode          TransportMode
  travelClass   TravelClass
  departAt      DateTime
  arriveAt      DateTime
  durationMin   Int
  stops         Int           @default(0)
  priceAmount   Float
  priceCurrency String        @default("PEN")
  seatsTotal    Int
  seatsAvailable Int
  baggageIncluded Boolean     @default(false)
  petsAllowed   Boolean       @default(false)
  accessible    Boolean       @default(false)
  amenities     String[]
  createdAt     DateTime      @default(now())

  seats         Seat[]
  bookings      Booking[]

  @@index([companyId])
  @@index([routeId])
  @@index([departAt])
}

model Seat {
  id        String     @id @default(cuid())
  vehicleId String?
  vehicle   Vehicle?   @relation(fields: [vehicleId], references: [id])
  tripId    String?
  trip      Trip?      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  label     String
  row       Int
  col       String
  status    SeatStatus @default(AVAILABLE)
  surcharge Float      @default(0)

  @@index([tripId])
}

// ----------------------------------------------------------------------------
// Usuarios y reservas
// ----------------------------------------------------------------------------

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String?
  fullName     String?
  role         UserRole  @default(TRAVELER)
  companyId    String?
  company      Company?  @relation(fields: [companyId], references: [id])
  createdAt    DateTime  @default(now())

  bookings     Booking[]

  @@index([companyId])
}

model Booking {
  id            String        @id @default(cuid())
  reference     String        @unique
  userId        String?
  user          User?         @relation(fields: [userId], references: [id])
  tripId        String
  trip          Trip          @relation(fields: [tripId], references: [id])
  status        BookingStatus @default(DRAFT)
  totalAmount   Float
  totalCurrency String        @default("PEN")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  passengers    Passenger[]
  payment       Payment?

  @@index([userId])
  @@index([tripId])
}

model Passenger {
  id             String  @id @default(cuid())
  bookingId      String
  booking        Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  firstName      String
  lastName       String
  documentType   String  @default("dni")
  documentNumber String
  seatLabel      String?

  @@index([bookingId])
}

model Payment {
  id        String        @id @default(cuid())
  bookingId String        @unique
  booking   Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  provider  String // stripe | paypal | mercadopago | transfer | qr | wallet
  status    PaymentStatus @default(PENDING)
  amount    Float
  currency  String        @default("PEN")
  createdAt DateTime      @default(now())
}

// ============================================================================
// CRM FLYALWAYS — módulo de gestión interna de la agencia.
//
// Tablas net-new, prefijadas `Crm`, que NO alteran ninguno de los modelos de
// transporte de arriba. Diseño: dinero en Decimal(12,2) + columna de moneda,
// soft-delete (`deletedAt`), auditoría (`createdById`/`updatedById`) e índices
// en claves foráneas y filtros frecuentes. Las uniones de string (status,
// kind, method, …) viven como `String` —el contrato de validación son las
// uniones de @vialta/types— para evitar migraciones por cada valor nuevo.
// Los arreglos de detalle anidados (segmentos, ítems, abonos, archivos,
// actividad) se guardan como `Json` para fidelidad con las formas del front.
// ============================================================================

/// Personal de la agencia con credenciales (primera autenticación real del proyecto).
model CrmUser {
  id               String    @id @default(cuid())
  name             String
  initials         String
  email            String    @unique
  passwordHash     String
  role             String // admin | supervisor | agent | accounting | marketing
  color            String?
  active           Boolean   @default(true)
  twoFactorEnabled Boolean   @default(false)
  lastActiveAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  sessions CrmSession[]

  @@index([role])
}

/// Sesiones activas (para el panel de Seguridad de Ajustes).
model CrmSession {
  id           String   @id @default(cuid())
  userId       String
  user         CrmUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  device       String
  browser      String
  ip           String
  location     String
  current      Boolean  @default(false)
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([userId])
}

/// Bitácora de auditoría (creación/edición/login/exportación/permisos).
model CrmAuditEntry {
  id            String   @id @default(cuid())
  actor         String
  actorInitials String
  action        String // create | update | delete | login | logout | export | permission_change
  entity        String
  detail        String?
  ip            String?
  at            DateTime @default(now())

  @@index([at])
}

/// Agente de ventas con métricas de rendimiento.
model CrmAgent {
  id               String     @id @default(cuid())
  name             String
  initials         String
  email            String
  role             String
  sales            Int        @default(0)
  revenueAmount    Decimal    @default(0) @db.Decimal(12, 2)
  commissionPct    Float      @default(0)
  commissionEarned Decimal    @default(0) @db.Decimal(12, 2)
  goalAmount       Decimal    @default(0) @db.Decimal(12, 2)
  goalPct          Float      @default(0)
  activeClients    Int        @default(0)
  rating           Float      @default(0)
  status           String     @default("active")
  currency         String     @default("BOB")
  joinedAt         DateTime
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  deletedAt        DateTime?

  customers CrmCustomer[]

  @@index([status])
}

/// Cliente — entidad central del módulo de Clientes (ficha 360°).
model CrmCustomer {
  id                   String    @id @default(cuid())
  firstName            String
  lastName             String
  documentType         String    @default("dni") // dni | passport | ce | other
  documentNumber       String
  passportNumber       String?
  passportExpiry       DateTime?
  birthDate            DateTime?
  nationality          String    @default("Boliviana")
  phone                String?
  whatsapp             String?
  email                String
  address              String?
  city                 String?
  country              String    @default("Bolivia")
  assignedAgentId      String
  assignedAgentName    String
  status               String    @default("active") // active | inactive | prospect | vip
  tags                 String[]
  notes                String?
  totalSpentAmount     Decimal   @default(0) @db.Decimal(12, 2)
  currency             String    @default("BOB")
  tripsCount           Int       @default(0)
  favoriteDestinations String[]
  favoriteAirlines     String[]
  files                Json      @default("[]")
  activity             Json      @default("[]")
  createdAt            DateTime  @default(now())
  lastActivityAt       DateTime?
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?
  createdById          String?
  updatedById          String?

  assignedAgent CrmAgent     @relation(fields: [assignedAgentId], references: [id])
  tickets       CrmTicket[]
  payments      CrmPayment[]

  @@index([assignedAgentId])
  @@index([status])
  @@index([email])
}

/// Pasaje / boleto — núcleo del módulo de ventas.
model CrmTicket {
  id               String    @id @default(cuid())
  code             String    @unique
  customerId       String?
  customerName     String
  agentId          String
  agentName        String
  airline          String
  airlineCode      String
  pnr              String?
  gds              String?
  ticketNumber     String?
  originCity       String
  originCode       String
  destinationCity  String
  destinationCode  String
  tripType         String    @default("round_trip")
  travelClass      String    @default("ECONOMY")
  travelDate       DateTime
  passengerCount   Int       @default(1)
  fareAmount       Decimal   @default(0) @db.Decimal(12, 2)
  taxesAmount      Decimal   @default(0) @db.Decimal(12, 2)
  totalAmount      Decimal   @default(0) @db.Decimal(12, 2)
  commissionAmount Decimal   @default(0) @db.Decimal(12, 2)
  profitAmount     Decimal   @default(0) @db.Decimal(12, 2)
  currency         String    @default("BOB")
  providerId       String
  providerName     String
  status           String    @default("quote") // quote | reserved | confirmed | issued | cancelled | refunded | reissued
  segments         Json      @default("[]")
  extras           Json      @default("{}")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?
  createdById      String?
  updatedById      String?

  customer CrmCustomer? @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([status])
  @@index([travelDate])
}

/// Cotización del Cotizador.
model CrmQuote {
  id            String    @id @default(cuid())
  code          String    @unique
  customerId    String?
  customerName  String
  customerEmail String?
  customerPhone String?
  agentName     String
  items         Json      @default("[]")
  currency      String    @default("BOB")
  taxPct        Float     @default(0)
  validUntil    DateTime
  status        String    @default("draft") // draft | sent | accepted | rejected | expired | converted
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  @@index([status])
}

/// Pago con su historial de abonos (transactions Json).
model CrmPayment {
  id           String    @id @default(cuid())
  code         String    @unique
  customerId   String?
  customerName String
  concept      String
  relatedCode  String?
  method       String // cash | card | qr | transfer | paypal | stripe
  totalAmount  Decimal   @default(0) @db.Decimal(12, 2)
  paidAmount   Decimal   @default(0) @db.Decimal(12, 2)
  currency     String    @default("BOB")
  status       String    @default("pending") // pending | partial | paid | refunded
  dueDate      DateTime?
  agentName    String
  transactions Json      @default("[]")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  createdById  String?
  updatedById  String?

  customer CrmCustomer? @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([status])
}

/// Documento generado (factura, recibo, voucher, …).
model CrmDocument {
  id            String    @id @default(cuid())
  code          String    @unique
  kind          String // invoice | receipt | credit_note | voucher | itinerary | confirmation | contract
  customerName  String
  customerEmail String?
  customerPhone String?
  relatedCode   String?
  concept       String
  amountValue   Decimal?  @db.Decimal(12, 2)
  currency      String?   @default("BOB")
  issuedAt      DateTime
  status        String    @default("issued") // issued | void
  agentName     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  @@index([kind])
}

/// Paquete turístico.
model CrmPackage {
  id           String    @id @default(cuid())
  code         String    @unique
  name         String
  type         String // tour | hotel | excursion | cruise | transfer | insurance | vehicle
  destination  String
  durationDays Int       @default(1)
  priceAmount  Decimal   @default(0) @db.Decimal(12, 2)
  currency     String    @default("BOB")
  providerName String
  includes     String[]
  status       String    @default("active") // active | draft | inactive
  soldCount    Int       @default(0)
  description  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  @@index([type])
  @@index([status])
}

/// Proveedor (operador, hotel, aerolínea, mayorista, seguro, transporte).
model CrmProvider {
  id            String    @id @default(cuid())
  name          String
  type          String // operator | hotel | airline | wholesaler | insurance | transport
  contactName   String?
  email         String?
  phone         String?
  city          String?
  country       String    @default("Bolivia")
  rating        Float     @default(0)
  status        String    @default("active") // active | inactive
  balanceAmount Decimal?  @db.Decimal(12, 2)
  currency      String?   @default("BOB")
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  @@index([type])
  @@index([status])
}

/// Tarea interna (gestor tipo kanban).
model CrmTask {
  id               String    @id @default(cuid())
  title            String
  description      String?
  priority         String    @default("medium") // low | medium | high | urgent
  status           String    @default("todo") // todo | in_progress | done
  dueDate          DateTime?
  assigneeId       String
  assignee         String
  assigneeInitials String
  relatedTo        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  @@index([status])
  @@index([assigneeId])
}

/// Evento de agenda / calendario.
model CrmCalendarEvent {
  id           String   @id @default(cuid())
  kind         String // departure | flight | meeting | follow_up | payment | birthday | passport_renewal | reminder
  title        String
  date         DateTime @db.Date
  time         String?
  customerName String?
  createdAt    DateTime @default(now())

  @@index([date])
}

/// Campaña de marketing (con métricas).
model CrmCampaign {
  id              String    @id @default(cuid())
  name            String
  channel         String // email | whatsapp | sms | push
  status          String    @default("draft") // draft | scheduled | active | completed | paused
  audience        String    @default("all")
  subject         String?
  owner           String
  scheduledAt     DateTime?
  sentAt          DateTime?
  metricsAudience Int       @default(0)
  sent            Int       @default(0)
  opened          Int       @default(0)
  clicked         Int       @default(0)
  converted       Int       @default(0)
  revenueAmount   Decimal?  @db.Decimal(12, 2)
  currency        String?   @default("BOB")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([status])
}

/// Etapa del embudo de conversión (agregado de marketing).
model CrmFunnelStage {
  id        String @id @default(cuid())
  label     String
  value     Int    @default(0)
  sortOrder Int    @default(0)

  @@index([sortOrder])
}

/// Automatización disparada por eventos del negocio.
model CrmAutomation {
  id        String    @id @default(cuid())
  name      String
  trigger   String // payment_due | trip_upcoming | birthday | inactive_client | quote_followup | passport_expiry
  channel   String // email | whatsapp | sms | push
  status    String    @default("active") // active | paused
  timing    String
  runs      Int       @default(0)
  lastRunAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status])
}

/// Snapshot de agregados precomputados (dashboard, reportes). Vista derivada
/// servida por la API; reemplazable por cómputo en vivo más adelante.
model CrmSnapshot {
  key       String   @id // "dashboard" | "reports"
  data      Json
  updatedAt DateTime @updatedAt
}

/// Notificación de la bandeja unificada.
model CrmNotification {
  id        String   @id @default(cuid())
  kind      String // payment | trip | task | birthday | campaign | system
  channel   String // email | whatsapp | sms | push | in_app
  status    String   @default("sent") // sent | scheduled | failed | read
  title     String
  body      String
  recipient String?
  at        DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([status])
}

// ============================================================================
// WEB — modelos de lectura del frontend público (perfil, notificaciones,
// seguimiento). Datos "aplanados" para servir sin re-resolver el catálogo.
// Fechas como String para preservar el valor exacto que consume la web.
// ============================================================================

model WebAccount {
  id          String @id @default("me")
  fullName    String
  email       String
  initials    String
  memberSince String
  tier        String
  points      Int
}

model WebBookingRecord {
  id              String  @id
  reference       String
  status          String // upcoming | completed | cancelled
  mode            String
  operatorName    String
  operatorMark    String
  operatorColor   String
  originCity      String
  originCode      String
  destinationCity String
  destinationCode String
  departAt        String
  arriveAt        String
  travelClass     String
  passengers      Int
  seats           String[]
  totalAmount     Float
  totalCurrency   String
  favorite        Boolean @default(false)
  sort            Int     @default(0)
}

model WebInvoice {
  id               String @id
  number           String
  bookingReference String
  date             String
  amount           Float
  currency         String
  status           String // paid | pending | refunded
  sort             Int    @default(0)
}

model WebPaymentMethod {
  id              String  @id
  kind            String // card | paypal | wallet
  label           String
  last4           String?
  expiry          String?
  balanceAmount   Float?
  balanceCurrency String?
  isDefault       Boolean @default(false)
  sort            Int     @default(0)
}

model WebFavoriteRoute {
  id                String @id
  mode              String
  originCity        String
  originCode        String
  destinationCity   String
  destinationCode   String
  fromPriceAmount   Float
  fromPriceCurrency String
  sort              Int    @default(0)
}

model WebNotification {
  id        String  @id
  title     String
  body      String
  channel   String // email | sms | push | whatsapp
  category  String // booking | trip | promo | payment | account
  createdAt String
  read      Boolean @default(false)
  href      String?
  sort      Int     @default(0)
}

model WebNotificationPreference {
  id         String @id @default("default")
  email      String
  phone      String
  whatsapp   String
  categories Json
}

model WebTripTracking {
  reference       String @id
  mode            String
  operatorName    String
  operatorMark    String
  operatorColor   String
  vehicleName     String
  originCity      String
  originCode      String
  destinationCity String
  destinationCode String
  status          String
  progressPct     Int
  departAt        String
  etaAt           String
  distanceTotalKm Int
  speedKmh        Int
  path            Json
  waypoints       Json
}
