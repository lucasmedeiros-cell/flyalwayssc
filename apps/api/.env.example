# Copia este archivo a .env y ajusta los valores.

# Postgres (local o Supabase). El API arranca aunque no haya DB:
# las consultas que la requieran fallarán hasta configurarla.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vialta?schema=public"

# Puerto del API
PORT=4000

# Origen permitido para CORS (frontend)
WEB_ORIGIN="http://localhost:3000"
